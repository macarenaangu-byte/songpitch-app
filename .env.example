# ─── Supabase (Required) ─────────────────────────────────────────────────────
# Get these from: https://app.supabase.com → Project Settings → API
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key-here

# ─── LegalSplits AI (Optional) ───────────────────────────────────────────────
# Powers the Split Sheet Analyzer and PDF Generator on the Splits page.
# Get your key from https://legalsplits.ai — leave empty to disable those features.
REACT_APP_LEGALSPLITS_API_URL=https://legalsplits-ai.onrender.com
REACT_APP_LEGALSPLITS_API_KEY=lsai_your-key-here

# ─── AI Audio Analysis Server (Optional) ────────────────────────────────────
# FastAPI ML server for genre/mood prediction. Leave empty to use rule-based fallback.
REACT_APP_AI_API_URL=
